    },
    {
      "label": "maui: build android",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/VinhKhanhFoodStreet.csproj",
        "-f",
        "net10.0-android",
        "-c",
        "Debug"
      ],
      "problemMatcher": "$msCompile",
      "group": "build"
    }
  ]
}
