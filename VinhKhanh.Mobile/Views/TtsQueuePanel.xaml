<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:VinhKhanh.Mobile.ViewModels"
             x:Class="VinhKhanh.Mobile.Views.TtsQueuePanel"
             IsVisible="{Binding IsPanelVisible}">

    <Frame BackgroundColor="#CC1A1A2E" CornerRadius="16" Padding="12" Margin="8,0,8,8">
        <VerticalStackLayout Spacing="8">

            <!-- Đang phát -->
            <HorizontalStackLayout Spacing="8" IsVisible="{Binding IsPlaying}">
                <Label Text="🔊" FontSize="16" VerticalOptions="Center"/>
                <Label Text="{Binding CurrentlyPlayingName}"
                       FontSize="14" FontAttributes="Bold"
                       TextColor="White" VerticalOptions="Center"
                       LineBreakMode="TailTruncation" MaxLines="1"/>
                <Label Text="Đang phát" FontSize="12" TextColor="#FF7F50" VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <!-- Hàng chờ -->
            <CollectionView ItemsSource="{Binding QueueItems}"
                            IsVisible="{Binding QueueItems.Count, Converter={StaticResource IntToBoolConverter}}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Label Text="{Binding Name}" FontSize="13" TextColor="#CCFFFFFF"
                               Padding="4,2" LineBreakMode="TailTruncation" MaxLines="1"/>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Nút điều khiển -->
            <HorizontalStackLayout Spacing="8" HorizontalOptions="End">
                <Button Text="Bỏ qua" Command="{Binding SkipCommand}"
                        BackgroundColor="#FF7F50" TextColor="White"
                        CornerRadius="8" Padding="12,6" FontSize="13"
                        IsVisible="{Binding IsPlaying}"/>
                <Button Text="Xóa hàng chờ" Command="{Binding ClearQueueCommand}"
                        BackgroundColor="#444" TextColor="White"
                        CornerRadius="8" Padding="12,6" FontSize="13"/>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </Frame>
</ContentView>
