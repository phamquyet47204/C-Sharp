<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="http://schemas.microsoft.com/dotnet/2021/maui/maps"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="VinhKhanhFoodStreet.MainPage"
             BackgroundColor="White">

    <Grid RowDefinitions="Auto,Auto,*">
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Padding="20,16" BackgroundColor="#FF7F50">
            <Label x:Name="PageTitleLabel"
                   Grid.Column="0"
                   Text="Vĩnh Khánh Food Street"
                   TextColor="White"
                   FontSize="18"
                   FontAttributes="Bold"
                   VerticalOptions="Center" />
            <Button x:Name="LanguageButton"
                    Grid.Column="1"
                    Text="VN"
                    Clicked="OnToggleLanguage" />
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="*,*" Padding="16,12" ColumnSpacing="10" BackgroundColor="#F8F8F8">
            <Button x:Name="MapTabButton" Text="Bản đồ" Clicked="OnSwitchToMapTab" />
            <Button x:Name="ListTabButton" Grid.Column="1" Text="Danh sách" Clicked="OnSwitchToListTab" />
        </Grid>

        <Grid Grid.Row="2">
            <Grid x:Name="MapPanel" RowDefinitions="*,Auto">
                <maps:Map x:Name="PoiMap"
                          Grid.Row="0"
                          IsShowingUser="True"
                          IsTrafficEnabled="False" />

                <VerticalStackLayout Grid.Row="0" Padding="16" Spacing="12">
                    <Border Stroke="#E0E0E0" StrokeThickness="1" BackgroundColor="White" Padding="10" StrokeShape="RoundRectangle 12">
                        <Picker x:Name="CategoryPicker"
                                Title="Chọn phân loại"
                                SelectedIndexChanged="OnCategoryPickerChanged"
                                TextColor="#1A1A1A"
                                TitleColor="#666666"
                                BackgroundColor="Transparent" />
                    </Border>
                </VerticalStackLayout>

                <!-- POI Quick Card — hiện khi bấm pin -->
                <Border x:Name="PinQuickCard"
                        Grid.Row="0"
                        IsVisible="False"
                        VerticalOptions="End"
                        HorizontalOptions="Fill"
                        Margin="12,0,12,16"
                        BackgroundColor="White"
                        StrokeShape="RoundRectangle 16"
                        Stroke="#E0E0E0"
                        StrokeThickness="1">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.15"/>
                    </Border.Shadow>
                    <Grid ColumnDefinitions="*,Auto,Auto" Padding="14,12" ColumnSpacing="10">
                        <Label x:Name="PinCardNameLabel"
                               Grid.Column="0"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#1A1A1A"
                               VerticalOptions="Center"
                               LineBreakMode="TailTruncation"
                               MaxLines="1"/>
                        <Button x:Name="PinCardPlayButton"
                                Grid.Column="1"
                                Text="🔊"
                                FontSize="20"
                                BackgroundColor="#FF7F50"
                                TextColor="White"
                                CornerRadius="24"
                                WidthRequest="48"
                                HeightRequest="48"
                                Padding="0"
                                Clicked="OnPinCardPlay"/>
                        <Button Grid.Column="2"
                                Text="✕"
                                FontSize="16"
                                BackgroundColor="Transparent"
                                TextColor="#999"
                                WidthRequest="36"
                                HeightRequest="36"
                                Padding="0"
                                Clicked="OnPinCardClose"/>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Padding="10" Margin="12" IsVisible="False">
                    <VerticalStackLayout Spacing="2">
                        <Label x:Name="LocationStatusLabel" Text="Đang kiểm tra GPS..." />
                        <Label x:Name="LocationLabel" Text="--, --" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Grid x:Name="ListPanel" IsVisible="False" RowDefinitions="Auto,Auto,*">
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Padding="20,14,20,10">
                    <Label x:Name="ListHeaderTitleLabel" Grid.Column="0" Text="Danh Sách Quán Ăn" />
                    <Label x:Name="PoisCountLabel" Grid.Column="1" Text="(0)" />
                </Grid>

                <Grid Grid.Row="1" ColumnDefinitions="Auto,*" Padding="20,0,20,10" ColumnSpacing="12">
                    <Button x:Name="SearchToggleButton" Grid.Column="0" Text="🔍" Clicked="OnToggleSearch" />
                    <Border x:Name="SearchContainer" Grid.Column="1" IsVisible="False">
                        <SearchBar x:Name="SearchBarPoi" Placeholder="Tìm quán ăn..." SearchButtonPressed="OnSearchPoi" />
                    </Border>
                </Grid>

                <CollectionView x:Name="PoiCollectionView" Grid.Row="2" SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="16,0"
                                    Padding="14"
                                    BackgroundColor="White"
                                    Stroke="#E8E8E8"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 18">
                                <Grid ColumnDefinitions="104,*,Auto" ColumnSpacing="14">
                                    <Border Stroke="#F1F1F1"
                                            StrokeThickness="1"
                                            BackgroundColor="#FAFAFA"
                                            StrokeShape="RoundRectangle 16"
                                            Padding="0">
                                        <Image Source="{Binding PoiImageSource}"
                                               WidthRequest="104"
                                               HeightRequest="96"
                                               Aspect="AspectFill" />
                                    </Border>

                                    <VerticalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                                        <Label Text="{Binding Name}"
                                               FontSize="17"
                                               FontAttributes="Bold"
                                               TextColor="#1A1A1A"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="2" />
                                        <Label Text="{Binding Description}"
                                               FontSize="12"
                                               TextColor="#666666"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="2" />
                                             <Border BackgroundColor="#FFF3EE"
                                                  Stroke="#FFD3C2"
                                                  StrokeThickness="1"
                                                  StrokeShape="RoundRectangle 12"
                                                  HorizontalOptions="Start"
                                                  Padding="10,4">
                                              <Label Text="{Binding CategoryDisplayName}"
                                                  FontSize="11"
                                                  TextColor="#FF7F50" />
                                             </Border>
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Grid.Column="2"
                                                         Spacing="8"
                                                         VerticalOptions="Center"
                                                         HorizontalOptions="Center">
                                        <Button Text="🔊"
                                                WidthRequest="42"
                                                HeightRequest="42"
                                                CornerRadius="21"
                                                BackgroundColor="#FF7F50"
                                                TextColor="White"
                                                Clicked="OnPlayPoi" />
                                        <Button Text="🧭"
                                                WidthRequest="42"
                                                HeightRequest="42"
                                                CornerRadius="21"
                                                BackgroundColor="#6B4C8A"
                                                TextColor="White"
                                                Clicked="OnNavigatePoi" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </Grid>

        <toolkit:MediaElement x:Name="NarrationPlayer"
                              HeightRequest="1"
                              WidthRequest="1"
                              IsVisible="False"
                              ShouldAutoPlay="False"
                              ShouldShowPlaybackControls="False" />
    </Grid>
</ContentPage>