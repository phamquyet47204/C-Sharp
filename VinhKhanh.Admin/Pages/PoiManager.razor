@page "/pois"
@inject HttpClient Http
@inject IJSRuntime JS

<h3>Quản lý POI – Phố Vĩnh Khánh</h3>

<button class="btn btn-primary mb-3" @onclick="() => OpenForm(new())">+ Thêm quán</button>

<table class="table table-striped">
    <thead><tr><th>Tên</th><th>Tọa độ</th><th>Bán kính</th><th>Ưu tiên</th><th></th></tr></thead>
    <tbody>
    @foreach (var poi in _pois)
    {
        <tr>
            <td>@poi.Name</td>
            <td>@poi.Latitude.ToString("F5"), @poi.Longitude.ToString("F5")</td>
            <td>@poi.Radius m</td>
            <td>@poi.Priority</td>
            <td>
                <button class="btn btn-sm btn-warning" @onclick="() => OpenForm(poi)">Sửa</button>
                <button class="btn btn-sm btn-danger"  @onclick="() => DeleteAsync(poi.Id)">Xóa</button>
            </td>
        </tr>
    }
    </tbody>
</table>

@if (_editing is not null)
{
    <div class="card p-3 mt-3" style="max-width:500px">
        <h5>@(_editing.Id == 0 ? "Thêm mới" : "Chỉnh sửa")</h5>
        <EditForm Model="_editing" OnValidSubmit="SaveAsync">
            <DataAnnotationsValidator/>
            <div class="mb-2"><label>Tên quán</label><InputText class="form-control" @bind-Value="_editing.Name"/></div>
            <div class="mb-2"><label>Thuyết minh</label><InputTextArea class="form-control" rows="3" @bind-Value="_editing.Description"/></div>
            <div class="row mb-2">
                <div class="col"><label>Latitude</label><InputNumber class="form-control" @bind-Value="_editing.Latitude"/></div>
                <div class="col"><label>Longitude</label><InputNumber class="form-control" @bind-Value="_editing.Longitude"/></div>
            </div>
            <div class="row mb-2">
                <div class="col"><label>Bán kính (m)</label><InputNumber class="form-control" @bind-Value="_editing.Radius"/></div>
                <div class="col"><label>Ưu tiên</label><InputNumber class="form-control" @bind-Value="_editing.Priority"/></div>
            </div>
            <button type="submit" class="btn btn-success">Lưu</button>
            <button type="button" class="btn btn-secondary ms-2" @onclick="() => _editing = null">Hủy</button>
        </EditForm>
    </div>
}

@code {
    private List<Poi> _pois = [];
    private Poi? _editing;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    async Task LoadAsync() => _pois = await Http.GetFromJsonAsync<List<Poi>>("api/pois") ?? [];

    void OpenForm(Poi poi) => _editing = new Poi
    {
        Id = poi.Id, Name = poi.Name, Description = poi.Description,
        Latitude = poi.Latitude, Longitude = poi.Longitude,
        Radius = poi.Radius == 0 ? 15 : poi.Radius, Priority = poi.Priority
    };

    async Task SaveAsync()
    {
        if (_editing!.Id == 0)
            await Http.PostAsJsonAsync("api/pois", _editing);
        else
            await Http.PutAsJsonAsync($"api/pois/{_editing.Id}", _editing);

        _editing = null;
        await LoadAsync();
    }

    async Task DeleteAsync(int id)
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Xóa quán này?")) return;
        await Http.DeleteAsync($"api/pois/{id}");
        await LoadAsync();
    }
}
