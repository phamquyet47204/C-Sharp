@page "/heatmap"
@inject HttpClient Http

<h3>Heatmap – Thống kê thuyết minh</h3>

<table class="table">
    <thead><tr><th>Quán</th><th>Lượt nghe</th><th>Lần cuối</th></tr></thead>
    <tbody>
    @foreach (var row in _stats)
    {
        <tr>
            <td>@row.PoiName</td>
            <td>
                <div class="progress">
                    <div class="progress-bar" style="width:@(row.Percent)%">@row.Count</div>
                </div>
            </td>
            <td>@row.LastTriggered.ToLocalTime().ToString("dd/MM HH:mm")</td>
        </tr>
    }
    </tbody>
</table>

@code {
    private List<HeatmapRow> _stats = [];

    protected override async Task OnInitializedAsync()
    {
        var raw = await Http.GetFromJsonAsync<List<HeatmapRow>>("api/heatmap") ?? [];
        var max = raw.Max(r => r.Count);
        _stats = raw.Select(r => r with { Percent = max > 0 ? r.Count * 100 / max : 0 })
                    .OrderByDescending(r => r.Count).ToList();
    }

    record HeatmapRow(int PoiId, string PoiName, int Count, DateTime LastTriggered)
    {
        public int Percent { get; init; }
    }
}
